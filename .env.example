# OpenAI — Sea Launch AI
OPENAI_API_KEY=sk-...

# 模型(可选)
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# demo 兜底:true 时 /api/run 始终返回 contract/mock-result.json(铁律 3 的安全网)
DEMO_MOCK_ONLY=false

# Packaging Agent:false 时只产出 prompt + fallback 图,不真调图像生成(等价 ?images=0)
LIVE_IMAGE_GENERATION=true

# 数据源:fixture 时 Shopee/1688 走 seed/,OpenAI 文本与图像仍可 live
PROVIDER_MODE=fixture

# audit 快照存储位置(见 roadmap §10)
AUDIT_STORAGE=local
