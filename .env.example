# OpenAI — Sea Launch AI
OPENAI_API_KEY=sk-...

# 模型(可选)
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2


# 数据策略:Shopee/1688/FX 走 seed/ 适配器(既定数据策略,不实时爬);
# shipping(easyship)与图像生成走 live provider。

# Logistics / landed-cost provider for live harness
LOGISTICS_PROVIDER=easyship
LOGISTICS_QUOTE_MODE=freight_and_duties
EASYSHIP_API_KEY=prod_...
EASYSHIP_API_BASE_URL=https://public-api.easyship.com
EASYSHIP_API_VERSION=2024-09
HS_CODE_PROVIDER=easyship
TAX_DUTY_PROVIDER=easyship
EASYSHIP_FORWARDER_FALLBACK=true

# 数据检索模式(market/sourcing 的浏览器抓取):seed=只读 seed/;live=接 Chrome provider。
BROWSER_RETRIEVAL_MODE=seed

# live 图像生成失败时是否回退到 seed SVG(默认 false:失败即报错,不静默兜底)。
ALLOW_IMAGE_FALLBACK=false

# audit 快照存储位置(见 roadmap §10)
AUDIT_STORAGE=local

# --- API server (仓库根应用) ---
# 跨源部署时允许的前端 origin(CORS)。同源 nginx 部署(推荐)留空即可。
# 例:ALLOWED_ORIGIN=http://localhost:3001 或 https://demo.example.com
ALLOWED_ORIGIN=

# 是否在 500 响应里回传内部错误详情(仅调试用,生产保持 false)。
DEBUG_ERRORS=false

# --- Frontend (frontend/ 应用,build 时注入) ---
# 浏览器端请求 API 的 base URL。
# 推荐:留空 = 同源(配合 nginx 把 /api 与 /generated 代到 api 容器,见 docs/DEPLOY.md §3)。
# 仅拆端口/跨源调试时才设为可达的绝对地址(不能是裸 localhost 远程部署),
# 且需在 API 侧设置 ALLOWED_ORIGIN 开启 CORS。
NEXT_PUBLIC_API_BASE_URL=
