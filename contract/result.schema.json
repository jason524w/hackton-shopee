{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sea Launch AI RunResult",
  "description": "Contract returned by POST /api/run. contract/result.ts is the CANONICAL type; this schema is the backend validation target kept in sync with it. Frontend renders against result.ts + mock-result.json. Run scripts/check-contract.mjs to verify mock-result.json conforms.",
  "type": "object",
  "required": ["run_id", "audit_run_id", "created_at", "currency", "brief", "product_directions", "market_trend_agent_output", "sourcing_agent_output", "agents", "opportunities", "committee", "selected_listing"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "audit_run_id": { "type": "string" },
    "created_at": { "type": "string" },
    "currency": { "type": "string" },
    "brief": { "$ref": "#/$defs/brief" },
    "product_directions": { "type": "array", "items": { "$ref": "#/$defs/productDirection" }, "minItems": 1 },
    "market_trend_agent_output": { "$ref": "#/$defs/marketTrendAgentOutput" },
    "sourcing_agent_output": { "$ref": "#/$defs/sourcingAgentOutput" },
    "agents": { "type": "array", "items": { "$ref": "#/$defs/agent" }, "minItems": 1 },
    "opportunities": { "type": "array", "items": { "$ref": "#/$defs/opportunity" }, "minItems": 1 },
    "committee": { "$ref": "#/$defs/committee" },
    "selected_listing": { "$ref": "#/$defs/selectedListing" }
  },
  "$defs": {
    "brief": {
      "type": "object",
      "required": ["target_market", "target_platform", "seller_type", "product_intent", "category", "budget", "target_margin", "max_fulfillment_days", "risk_appetite", "language"],
      "properties": {
        "target_market": { "type": "string" },
        "target_platform": { "enum": ["Shopee", "Lazada"] },
        "seller_type": { "type": "string" },
        "product_intent": { "type": "string" },
        "category": { "type": "string" },
        "budget": { "type": "number" },
        "target_margin": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_fulfillment_days": { "type": "number" },
        "risk_appetite": { "enum": ["conservative", "balanced", "aggressive"] },
        "language": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["label", "value"],
      "properties": { "label": { "type": "string" }, "value": { "type": "string" } }
    },
    "productDirection": {
      "type": "object",
      "required": ["id", "english_name", "chinese_name", "search_keyword"],
      "properties": {
        "id": { "type": "string" },
        "english_name": { "type": "string" },
        "chinese_name": { "type": "string" },
        "search_keyword": { "type": "string" }
      }
    },
    "trendSourceLink": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "priceBand": {
      "type": "object",
      "required": ["currency", "min", "max", "label"],
      "properties": {
        "currency": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "label": { "type": "string" }
      }
    },
    "reviewDensity": {
      "type": "object",
      "required": ["median_reviews", "top_listing_reviews", "reviewed_listing_ratio", "label"],
      "properties": {
        "median_reviews": { "type": "number" },
        "top_listing_reviews": { "type": "number" },
        "reviewed_listing_ratio": { "type": "number" },
        "label": { "type": "string" }
      }
    },
    "ratingDistribution": {
      "type": "object",
      "required": ["average_rating", "five_star_percent", "four_star_percent", "three_star_or_below_percent"],
      "properties": {
        "average_rating": { "type": "number" },
        "five_star_percent": { "type": "number" },
        "four_star_percent": { "type": "number" },
        "three_star_or_below_percent": { "type": "number" }
      }
    },
    "marketTrendSignal": {
      "type": "object",
      "required": ["product_direction_id", "product_direction", "platform", "demand_signal_score", "competitor_count", "price_band", "review_density", "rating_distribution", "trend_source_links"],
      "properties": {
        "product_direction_id": { "type": "string" },
        "product_direction": { "type": "string" },
        "platform": { "enum": ["Shopee SG"] },
        "demand_signal_score": { "type": "number" },
        "competitor_count": { "type": "number" },
        "price_band": { "$ref": "#/$defs/priceBand" },
        "review_density": { "$ref": "#/$defs/reviewDensity" },
        "rating_distribution": { "$ref": "#/$defs/ratingDistribution" },
        "trend_source_links": { "type": "array", "items": { "$ref": "#/$defs/trendSourceLink" } }
      }
    },
    "supplierCandidate": {
      "type": "object",
      "required": ["supplier_name", "location", "years_active", "price_cny", "minimum_order_quantity", "available_stock", "domestic_shipping_time_days"],
      "properties": {
        "supplier_name": { "type": "string" },
        "location": { "type": "string" },
        "years_active": { "type": "number" },
        "price_cny": { "type": "number" },
        "minimum_order_quantity": { "type": "number" },
        "available_stock": { "type": "number" },
        "domestic_shipping_time_days": { "type": "string" }
      }
    },
    "packageDimensions": {
      "type": "object",
      "required": ["length_cm", "width_cm", "height_cm", "label"],
      "properties": {
        "length_cm": { "type": "number" },
        "width_cm": { "type": "number" },
        "height_cm": { "type": "number" },
        "label": { "type": "string" }
      }
    },
    "sourcingSignal": {
      "type": "object",
      "required": ["product_direction_id", "product_direction", "platform", "search_keyword", "source_price", "supplier_candidates", "available_stock", "min_order_quantity", "estimated_domestic_shipping_time", "package_weight", "package_dimensions"],
      "properties": {
        "product_direction_id": { "type": "string" },
        "product_direction": { "type": "string" },
        "platform": { "enum": ["1688"] },
        "search_keyword": { "type": "string" },
        "source_price": { "type": "object" },
        "supplier_candidates": { "type": "array", "items": { "$ref": "#/$defs/supplierCandidate" } },
        "available_stock": { "type": "number" },
        "min_order_quantity": { "type": "number" },
        "estimated_domestic_shipping_time": { "type": "string" },
        "package_weight": { "type": "object" },
        "package_dimensions": { "$ref": "#/$defs/packageDimensions" }
      }
    },
    "marketTrendAgentOutput": {
      "type": "object",
      "required": ["platform", "purpose", "signals"],
      "properties": {
        "platform": { "enum": ["Shopee SG"] },
        "purpose": { "type": "string" },
        "signals": { "type": "array", "items": { "$ref": "#/$defs/marketTrendSignal" } }
      }
    },
    "sourcingAgentOutput": {
      "type": "object",
      "required": ["platform", "purpose", "signals"],
      "properties": {
        "platform": { "enum": ["1688"] },
        "purpose": { "type": "string" },
        "signals": { "type": "array", "items": { "$ref": "#/$defs/sourcingSignal" } }
      }
    },
    "agent": {
      "type": "object",
      "required": ["key", "name", "role", "status", "inputs_summary", "data_sources", "evidence", "key_judgment", "score", "confidence", "warnings"],
      "properties": {
        "key": { "enum": ["market", "sourcing", "margin", "risk", "listing", "packaging", "committee"] },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "status": { "enum": ["waiting", "running", "done", "blocked"] },
        "inputs_summary": { "type": "string" },
        "data_sources": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "key_judgment": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "risk_level": { "enum": ["low", "medium", "high"] },
        "structured_output": { "type": "object" }
      }
    },
    "costLine": {
      "type": "object",
      "required": ["label", "amount", "type"],
      "properties": {
        "label": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "enum": ["revenue", "cost", "net"] }
      }
    },
    "marginTier": {
      "type": "object",
      "required": ["net_profit", "net_margin"],
      "properties": { "net_profit": { "type": "number" }, "net_margin": { "type": "number" } }
    },
    "margin": {
      "type": ["object", "null"],
      "required": ["base", "low", "high", "cost_breakdown"],
      "properties": {
        "base": { "$ref": "#/$defs/marginTier" },
        "low": { "$ref": "#/$defs/marginTier" },
        "high": { "$ref": "#/$defs/marginTier" },
        "cost_breakdown": { "type": "array", "items": { "$ref": "#/$defs/costLine" } }
      }
    },
    "scores": {
      "type": "object",
      "required": ["profit", "demand", "compliance", "fulfillment", "packaging", "overall"],
      "properties": {
        "profit": { "type": "number" },
        "demand": { "type": "number" },
        "compliance": { "type": "number" },
        "fulfillment": { "type": "number" },
        "packaging": { "type": "number" },
        "overall": { "type": "number" }
      }
    },
    "opportunity": {
      "type": "object",
      "required": ["id", "is_primary", "name", "direction", "target_market", "target_platform", "source_price", "suggested_price", "minimum_viable_price", "gross_margin", "stock_status", "fulfillment_days", "market_heat", "risk_level", "decision", "decision_reason", "scores", "margin", "key_reasons"],
      "properties": {
        "id": { "type": "string" },
        "is_primary": { "type": "boolean" },
        "name": { "type": "string" },
        "direction": { "type": "string" },
        "target_market": { "type": "string" },
        "target_platform": { "type": "string" },
        "source_price": { "type": "number" },
        "suggested_price": { "type": "number" },
        "minimum_viable_price": { "type": "number" },
        "gross_margin": { "type": "number" },
        "stock_status": { "enum": ["in_stock", "low", "out"] },
        "fulfillment_days": { "type": "number" },
        "market_heat": { "enum": ["low", "medium", "high"] },
        "risk_level": { "enum": ["low", "medium", "high"] },
        "decision": { "enum": ["Go", "Watch", "Reject"] },
        "decision_reason": { "type": "string" },
        "scores": { "$ref": "#/$defs/scores" },
        "margin": { "$ref": "#/$defs/margin" },
        "key_reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tradeoff": {
      "type": "object",
      "required": ["opportunity_id", "conflict", "resolution"],
      "properties": {
        "opportunity_id": { "type": "string" },
        "conflict": { "type": "string" },
        "resolution": { "type": "string" }
      }
    },
    "committee": {
      "type": "object",
      "required": ["ranked_ids", "weights", "tradeoffs", "summary"],
      "properties": {
        "ranked_ids": { "type": "array", "items": { "type": "string" } },
        "weights": { "type": "object" },
        "tradeoffs": { "type": "array", "items": { "$ref": "#/$defs/tradeoff" } },
        "summary": { "type": "string" }
      }
    },
    "listingImage": {
      "type": "object",
      "required": ["type", "url", "prompt", "compliance"],
      "properties": {
        "type": { "enum": ["hero", "lifestyle", "feature"] },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "compliance": { "enum": ["ok", "needs_review", "rejected"] }
      }
    },
    "shopeeListing": {
      "type": "object",
      "required": ["item_name", "category", "category_id", "brand", "condition", "price", "stock", "sku", "variations", "attributes", "description", "bullet_points", "logistics", "required_fields_total", "required_fields_filled", "missing_fields"],
      "properties": {
        "item_name": { "type": "string" },
        "category": { "type": "string" },
        "category_id": { "type": "number" },
        "brand": { "type": "string" },
        "condition": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "sku": { "type": "string" },
        "variations": { "type": "array" },
        "attributes": { "type": "object" },
        "description": { "type": "string" },
        "bullet_points": { "type": "array", "items": { "type": "string" } },
        "logistics": { "type": "object" },
        "required_fields_total": { "type": "number" },
        "required_fields_filled": { "type": "number" },
        "missing_fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "selectedListing": {
      "type": "object",
      "required": ["opportunity_id", "platform", "market", "language", "shopee", "images", "compliance", "editable_json_ready"],
      "properties": {
        "opportunity_id": { "type": "string" },
        "platform": { "enum": ["Shopee", "Lazada"] },
        "market": { "type": "string" },
        "language": { "type": "string" },
        "shopee": { "$ref": "#/$defs/shopeeListing" },
        "images": { "type": "array", "items": { "$ref": "#/$defs/listingImage" } },
        "compliance": { "type": "object" },
        "editable_json_ready": { "type": "boolean" }
      }
    }
  }
}
